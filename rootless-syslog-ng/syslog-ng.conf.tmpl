@version: 4.9
@include "scl.conf"

options {
    threaded(yes);
    chain_hostnames(off);
    flush_lines(0);
    use_dns(no);
    use_fqdn(no);
    keep_hostname(no);
    keep_timestamp(no);
    time_reopen(10);
    use_uniqid(yes);
    stats(level(3) freq(3600));
};

source s_network {
    network(
        transport("udp")
        ip("0.0.0.0")
        port(5514)
        so_rcvbuf(425984)
        log-iw-size(10000)
        flags(no-parse)
    );
};
# =========================================================================
# 1. SOURCES
# =========================================================================

source s_udp_514 {
    network(
        ip("0.0.0.0")
        transport("udp")
        port(514)
        flags(no-parse)
    );
};

source s_udp_5514 {
    network(
        ip("0.0.0.0")
        transport("udp")
        port(5514)
        flags(no-parse)
    );
};

source s_udp_6514 {
    network(
        ip("0.0.0.0")
        transport("udp")
        port(6514)
        flags(no-parse)
    );
};

# =========================================================================
# 2. DESTINATIONS (HEC Endpoints)
# =========================================================================

destination d_http_514 {
    http(
        url("${S1_INGEST_URL}/services/collector/raw?sourcetype=my_parser_514")
        method("POST")
        headers("Authorization: Splunk ${S1_WRITE_TOKEN}") # Required for HEC auth
        body("${MSG}")
    );
};

destination d_http_5514 {
    http(
        url("${S1_INGEST_URL}/services/collector/raw?sourcetype=my_parser_5514")
        method("POST")
        headers("Authorization: Splunk ${S1_WRITE_TOKEN}") 
        body("${MSG}")
    );
};

destination d_http_6514 {
    http(
        url("${S1_INGEST_URL}/services/collector/raw?sourcetype=my_parser_6514")
        method("POST")
        headers("Authorization: Splunk ${S1_WRITE_TOKEN}") 
        body("${MSG}")
    );
};

# =========================================================================
# 3. LOG PATHS
# =========================================================================

log {
    source(s_udp_514);
    destination(d_http_514);
};

log {
    source(s_udp_5514);
    destination(d_http_5514);
};

log {
    source(s_udp_6514);
    destination(d_http_6514);
};
